@model StudentManagementSystem.Models.Mark
@{
    ViewData["Title"] = "Add Mark";
    Layout = "_Layout";
    var student = ViewBag.Student as StudentManagementSystem.Models.Student;
}

<div class="page-header">
    <a href="/Student/Details/@student?.Id" class="btn-back"><i class="fas fa-arrow-left"></i> Back</a>
    <div>
        <h2><i class="fas fa-plus-circle"></i> Add Mark</h2>
        <p class="sub">For: @student?.Name (@student?.RegisterNumber)</p>
    </div>
</div>

<div class="form-card">
    <form asp-action="AddMark" asp-controller="Student" method="post">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="StudentId" />
        <div class="form-grid">
            <div class="form-group">
                <label><i class="fas fa-book"></i> Subject *</label>
                <input asp-for="Subject" class="form-input" placeholder="e.g. Digital Electronics" required />
            </div>
            <div class="form-group">
                <label><i class="fas fa-tag"></i> Exam Type *</label>
                <select asp-for="ExamType" class="form-input" required>
                    <option value="">Select Type</option>
                    <option>Internal</option>
                    <option>External</option>
                    <option>Mid Semester</option>
                    <option>End Semester</option>
                </select>
            </div>
            <div class="form-group">
                <label><i class="fas fa-star"></i> Score *</label>
                <input asp-for="Score" type="number" step="0.5" class="form-input" min="0" required />
            </div>
            <div class="form-group">
                <label><i class="fas fa-star-half-alt"></i> Max Score *</label>
                <input asp-for="MaxScore" type="number" step="0.5" class="form-input" min="1" required />
            </div>
        </div>
        <div class="form-actions">

            <button type="submit" class="btn-primary"><i class="fas fa-save"></i> Save Mark</button>
        </div>
    </form>
</div>
