@model StudentManagementSystem.Models.Attendance
@{
    ViewData["Title"] = "Add Attendance";
    Layout = "_Layout";
    var student = ViewBag.Student as StudentManagementSystem.Models.Student;
}

<div class="page-header">
    <a href="/Student/Details/@student?.Id" class="btn-back"><i class="fas fa-arrow-left"></i> Back</a>
    <div>
        <h2><i class="fas fa-calendar-plus"></i> Add Attendance</h2>
        <p class="sub">For: @student?.Name (@student?.RegisterNumber)</p>
    </div>
</div>

<div class="form-card">
    <form asp-action="AddAttendance" asp-controller="Student" method="post">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="StudentId" />
        <div class="form-grid">
            <div class="form-group">
                <label><i class="fas fa-book"></i> Subject *</label>
                <input asp-for="Subject" class="form-input" placeholder="e.g. Digital Electronics" required />
            </div>
            <div class="form-group">
                <label><i class="fas fa-chalkboard"></i> Total Classes *</label>
                <input asp-for="TotalClasses" type="number" class="form-input" min="1" required />
            </div>
            <div class="form-group">
                <label><i class="fas fa-check-circle"></i> Attended Classes *</label>
                <input asp-for="AttendedClasses" type="number" class="form-input" min="0" required />
            </div>
        </div>
        <div class="form-actions">

            <button type="submit" class="btn-primary"><i class="fas fa-save"></i> Save Attendance</button>
        </div>
    </form>
</div>
