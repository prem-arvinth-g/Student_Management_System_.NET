@model StudentManagementSystem.Models.Student
@{
    ViewData["Title"] = "Edit Student";
    Layout = "_Layout";
    var role = Context.Session.GetString("UserRole");
    var departments = ViewBag.Departments as List<StudentManagementSystem.Models.Department>;
}

<div class="page-header">
    <a href="/Student/Details/@Model.Id" class="btn-back"><i class="fas fa-arrow-left"></i> Back</a>
    <div>
        <h2><i class="fas fa-edit"></i> Edit Student</h2>
        <p class="sub">Updating — @Model.Name (@Model.RegisterNumber)</p>
    </div>
</div>

<div class="form-card">
    <form asp-action="Edit" asp-controller="Student" asp-route-id="@Model.Id" method="post">
        @Html.AntiForgeryToken()

        <div class="form-grid">
            <div class="form-group">
                <label><i class="fas fa-user"></i> Full Name *</label>
                <input asp-for="Name" class="form-input" required />
                <span asp-validation-for="Name" class="field-error"></span>
            </div>

            <div class="form-group">
                <label><i class="fas fa-id-card"></i> Register Number *</label>
                <input asp-for="RegisterNumber" class="form-input" required />
            </div>

            <div class="form-group">
                <label><i class="fas fa-calendar"></i> Date of Birth *</label>
                <input asp-for="DateOfBirth" type="date" class="form-input" required />
            </div>

            <div class="form-group">
                <label><i class="fas fa-envelope"></i> Email</label>
                <input asp-for="Email" type="email" class="form-input" />
            </div>

            <div class="form-group">
                <label><i class="fas fa-phone"></i> Phone</label>
                <input asp-for="Phone" class="form-input" />
            </div>

            <div class="form-group">
                <label><i class="fas fa-layer-group"></i> Year *</label>
                <select asp-for="Year" class="form-input" required>
                    <option value="1">1st Year</option>
                    <option value="2">2nd Year</option>
                    <option value="3">3rd Year</option>
                    <option value="4">4th Year</option>
                </select>
            </div>

            <div class="form-group">
                <label><i class="fas fa-sitemap"></i> Section</label>
                <select asp-for="Section" class="form-input">
                    <option>A</option><option>B</option><option>C</option>
                </select>
            </div>

            @if (role == "Admin")
            {
                <div class="form-group">
                    <label><i class="fas fa-building"></i> Department</label>
                    <select asp-for="DepartmentId" class="form-input">
                        @foreach (var d in departments ?? new())
                        {
                            <option value="@d.Id" selected="@(d.Id == Model.DepartmentId ? "selected" : null)">@d.Name</option>
                        }
                    </select>
                </div>
            }

            <div class="form-group full-width">
                <label><i class="fas fa-map-marker-alt"></i> Address</label>
                <textarea asp-for="Address" class="form-input" rows="3"></textarea>
            </div>
        </div>

        <div class="form-actions">

            <button type="submit" class="btn-primary"><i class="fas fa-save"></i> Save Changes</button>
        </div>
    </form>
</div>
