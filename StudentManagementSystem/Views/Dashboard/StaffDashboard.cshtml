@model List<StudentManagementSystem.Models.Student>
@{
    ViewData["Title"] = "Staff Dashboard";
    Layout = "_Layout";
    var deptName = Context.Session.GetString("UserDept");
}

<div class="page-header">
    <div>
        <h2><i class="fas fa-users"></i> @deptName Student Details</h2>
        <p class="sub">@Model.Count student(s) in your department</p>
    </div>
</div>

<div style="display:flex; justify-content:space-between; align-items:center; gap:20px; margin-bottom:1.5rem;">
    <!-- Filter Bar -->
    <div class="filter-bar" style="flex-grow:1; margin-bottom:0; display:flex; align-items:center;">
        <div style="font-size:0.9rem; color:var(--text-muted);"><i class="fas fa-filter"></i> Department Students</div>
    </div>
    <a href="/Student/Create" class="btn-primary" title="Add Student" style="border-radius:50%; width:48px; height:48px; display:flex; align-items:center; justify-content:center; flex-shrink:0;">
        <i class="fas fa-plus"></i>
    </a>
</div>

@if (!Model.Any())
{
    <div class="empty-state">
        <i class="fas fa-user-slash"></i>
        <p>No students in your department yet.</p>
        <a href="/Student/Create" class="btn-primary">Create First Student</a>
    </div>
}
else
{
    <div class="card">
        <table class="data-table">
            <thead>
                <tr>
                    <th>Student Name</th>
                    <th>Register No</th>
                    <th>Class</th>
                    <th style="text-align:right">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var student in Model)
                {
                    <tr>
                        <td>
                            <div style="display:flex; align-items:center; gap:10px;">
                                <div class="student-avatar dept-@(student.Department?.Name?.ToLower())" style="width:32px; height:32px; font-size:0.9rem;">
                                    @student.Name[0]
                                </div>
                                <span style="font-weight:600">@student.Name</span>
                            </div>
                        </td>
                        <td style="font-family:monospace">@student.RegisterNumber</td>
                        <td>Year @student.Year, Sec @student.Section</td>
                        <td style="text-align:right">
                            <div style="position:relative; display:inline-block">
                                <button class="dots-btn" onclick="toggleMenu(@student.Id, event)">
                                    <i class="fas fa-ellipsis-v"></i>
                                </button>
                                <div class="dropdown-menu" id="menu-@student.Id" style="text-align:left">
                                    <a href="/Student/Details/@student.Id"><i class="fas fa-eye"></i> View</a>
                                    <a href="/Student/Edit/@student.Id"><i class="fas fa-edit"></i> Modify</a>
                                    <button class="delete-option" onclick="confirmDelete(@student.Id, '@student.Name')">
                                        <i class="fas fa-trash"></i> Delete
                                    </button>
                                </div>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

<!-- Delete Confirmation Modal -->
<div class="modal-overlay" id="deleteModal" style="display:none">
    <div class="modal-box">
        <i class="fas fa-exclamation-triangle modal-icon warn"></i>
        <h3>Confirm Delete</h3>
        <p id="deleteMsg">Are you sure?</p>
        <div class="modal-actions">
            <button class="btn-cancel" onclick="closeModal()">Cancel</button>
            <form id="deleteForm" method="post" style="display:inline">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn-danger">Delete</button>
            </form>
        </div>
    </div>
</div>

@section Scripts {
<script>
function toggleMenu(id, e) {
    e.stopPropagation();
    document.querySelectorAll('.dropdown-menu').forEach(m => m.classList.remove('show'));
    document.getElementById('menu-' + id).classList.toggle('show');
}
document.addEventListener('click', () => {
    document.querySelectorAll('.dropdown-menu').forEach(m => m.classList.remove('show'));
});
function confirmDelete(id, name) {
    document.getElementById('deleteMsg').textContent = `Delete student "${name}"? This cannot be undone.`;
    document.getElementById('deleteForm').action = '/Student/Delete/' + id;
    document.getElementById('deleteModal').style.display = 'flex';
}
function closeModal() {
    document.getElementById('deleteModal').style.display = 'none';
}
</script>
}
