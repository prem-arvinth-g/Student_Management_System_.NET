@model StudentManagementSystem.Models.StaffSubject
@{
    ViewData["Title"] = "Add Subject";
    Layout = "_Layout";
    var departments = ViewBag.Departments as List<StudentManagementSystem.Models.Department>;
}

<div class="page-header">
    <a href="/Staff/Profile" class="btn-back"><i class="fas fa-arrow-left"></i> Back</a>
    <div><h2><i class="fas fa-book-open"></i> Add Subject</h2></div>
</div>

<div class="form-card">
    <form asp-action="AddSubject" asp-controller="Staff" method="post">
        @Html.AntiForgeryToken()
        <input type="hidden" name="StaffId" value="@ViewBag.StaffId" />
        <div class="form-grid">
            <div class="form-group">
                <label><i class="fas fa-book"></i> Subject Name *</label>
                <input name="SubjectName" class="form-input" placeholder="e.g. Digital Electronics" required />
            </div>
            <div class="form-group">
                <label><i class="fas fa-hashtag"></i> Subject Code *</label>
                <input name="SubjectCode" class="form-input" placeholder="e.g. EC301" required />
            </div>
            <div class="form-group">
                <label><i class="fas fa-layer-group"></i> Year *</label>
                <select name="Year" class="form-input" required>
                    <option value="1">1st Year</option>
                    <option value="2">2nd Year</option>
                    <option value="3">3rd Year</option>
                    <option value="4">4th Year</option>
                </select>
            </div>
            <div class="form-group">
                <label><i class="fas fa-sitemap"></i> Section</label>
                <select name="Section" class="form-input">
                    <option>A</option><option>B</option><option>C</option>
                </select>
            </div>
            <div class="form-group">
                <label><i class="fas fa-building"></i> Department *</label>
                <select name="DepartmentId" class="form-input" required>
                    @foreach (var d in departments ?? new())
                    {
                        <option value="@d.Id">@d.Name</option>
                    }
                </select>
            </div>
        </div>
        <div class="form-actions">

            <button type="submit" class="btn-primary"><i class="fas fa-save"></i> Add Subject</button>
        </div>
    </form>
</div>
