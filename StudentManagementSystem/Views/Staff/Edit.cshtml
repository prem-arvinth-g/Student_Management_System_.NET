@model StudentManagementSystem.Models.User
@{
    ViewData["Title"] = "Edit Staff";
    Layout = "_Layout";
    var departments = ViewBag.Departments as List<StudentManagementSystem.Models.Department>;
}

<div class="page-header">
    <a href="/Staff/Index" class="btn-back"><i class="fas fa-arrow-left"></i> Back</a>
    <div><h2><i class="fas fa-edit"></i> Edit Staff — @Model.Name</h2></div>
</div>

<div class="form-card">
    <form asp-action="Edit" asp-controller="Staff" asp-route-id="@Model.Id" method="post">
        @Html.AntiForgeryToken()
        <div class="form-grid">
            <div class="form-group">
                <label><i class="fas fa-user"></i> Full Name *</label>
                <input name="Name" value="@Model.Name" class="form-input" required />
            </div>
            <div class="form-group">
                <label><i class="fas fa-envelope"></i> Email *</label>
                <input name="Email" value="@Model.Email" type="email" class="form-input" required />
            </div>
            <div class="form-group">
                <label><i class="fas fa-phone"></i> Phone</label>
                <input name="Phone" value="@Model.Phone" class="form-input" />
            </div>
            <div class="form-group">
                <label><i class="fas fa-lock"></i> New Password <small>(leave blank to keep current)</small></label>
                <input name="newPassword" type="password" class="form-input" placeholder="Leave blank to keep current" />
            </div>
            <div class="form-group">
                <label><i class="fas fa-building"></i> Department</label>
                <select name="DepartmentId" class="form-input">
                    @foreach (var d in departments ?? new())
                    {
                        <option value="@d.Id" selected="@(d.Id == Model.DepartmentId ? "selected" : null)">@d.Name</option>
                    }
                </select>
            </div>
        </div>
        <div class="form-actions">

            <button type="submit" class="btn-primary"><i class="fas fa-save"></i> Save Changes</button>
        </div>
    </form>
</div>
