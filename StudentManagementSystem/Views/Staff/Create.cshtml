@{
    ViewData["Title"] = "Create Staff";
    Layout = "_Layout";
    var departments = ViewBag.Departments as List<StudentManagementSystem.Models.Department>;
}

<div class="page-header">
    <a href="/Staff/Index" class="btn-back"><i class="fas fa-arrow-left"></i> Back</a>
    <div><h2><i class="fas fa-user-plus"></i> Add New Staff</h2></div>
</div>

<div class="form-card">
    <form asp-action="Create" asp-controller="Staff" method="post">
        @Html.AntiForgeryToken()
        <div class="form-grid">
            <div class="form-group">
                <label><i class="fas fa-user"></i> Full Name *</label>
                <input name="Name" class="form-input" placeholder="Staff Full Name" required />
            </div>
            <div class="form-group">
                <label><i class="fas fa-envelope"></i> Email *</label>
                <input name="Email" type="email" class="form-input" placeholder="staff@school.edu" required />
            </div>
            <div class="form-group">
                <label><i class="fas fa-phone"></i> Phone</label>
                <input name="Phone" class="form-input" placeholder="10-digit number" />
            </div>
            <div class="form-group">
                <label><i class="fas fa-lock"></i> Password *</label>
                <input name="password" type="password" class="form-input" placeholder="Set login password" required />
            </div>
            <div class="form-group">
                <label><i class="fas fa-building"></i> Department *</label>
                <select name="DepartmentId" class="form-input" required>
                    <option value="">Select Department</option>
                    @foreach (var d in departments ?? new())
                    {
                        <option value="@d.Id">@d.Name</option>
                    }
                </select>
            </div>
        </div>
        <div class="form-actions">

            <button type="submit" class="btn-primary"><i class="fas fa-save"></i> Create Staff</button>
        </div>
    </form>
</div>
